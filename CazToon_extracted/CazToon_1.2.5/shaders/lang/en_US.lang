value.END_EVENT_BLACKOUT.3.0=3s
value.END_EVENT_BLACKOUT.5.0=5s
value.END_EVENT_BLACKOUT.7.0=7s
value.END_EVENT_BLACKOUT.10.0=10s
value.END_EVENT_BLACKOUT.15.0=15s
value.END_EVENT_BLACKOUT.20.0=20s
