option.TEXTURE_PALETTE_LEVELS=Color Levels
option.TEXTURE_PALETTE_LEVELS.comment=Number of color levels per channel. Lower = more stylized, higher = smoother gradients.

screen.CG_VIGNETTE=Vignette
