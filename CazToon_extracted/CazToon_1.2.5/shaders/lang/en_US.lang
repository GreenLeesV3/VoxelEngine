# ============================================================================
#   1. LIGHTING
# ============================================================================

screen.LIGHTING=Lighting
screen.LIGHTING.comment=Shadow, ambient, and emissive light settings.

# --- Shadows ---

screen.SHADOWS=Shadows
screen.SHADOWS.comment=Directional sun/moon shadows, shadow map quality, and shadow color tinting.

screen.ADDONS=Addons
screen.ADDONS.comment=Settings for addon-driven features and extra integrations.
option.SHADOWS_ENABLED=Enable Shadows
option.SHADOWS_ENABLED.comment=Enable directional shadows cast by the sun and moon.

option.shadowMapResolution=Shadow Resolution
option.shadowMapResolution.comment=Shadow map texture size. Higher = sharper shadows but more GPU cost. Quartic distortion keeps detail high near the player.

option.SHADOW_DISTANCE_CHUNKS=Shadow Distance
option.SHADOW_DISTANCE_CHUNKS.comment=How far shadows render from the player (in chunks). Very long distances need low distortion.

option.SHADOW_DISTORTION=Shadow Distortion
option.SHADOW_DISTORTION.comment=Warps the shadow map to concentrate detail near the player. Lower = more uniform coverage (better for long distance), higher = sharper close-up shadows.

option.SHARP_SHADOWS=Sharp Shadows
option.SHARP_SHADOWS.comment=When enabled, uses sharp shadow sampling. Disable to use soft PCF-blurred shadows.

option.SHADOW_DEBUG_TINT=Shadow Debug Tint
option.SHADOW_DEBUG_TINT.comment=Turns direct shadowed areas bright red for debugging. If dark cave areas do not turn red, they are not coming from the shadow term.
option.CAVE_LIGHT_DEBUG=Cave Light Debug
option.CAVE_LIGHT_DEBUG.comment=Visualizes non-shadow cave lighting. Blue = low skylight, red = minimum brightness floor. If caves glow blue/red here, the darkness is from ambient/skylight logic, not shadows.
option.SHADOW_PCF_RADIUS=PCF Blur Radius
option.SHADOW_PCF_RADIUS.comment=Soft shadow blur size when Sharp Shadows is OFF. Higher values make shadow edges softer.

option.SHADOW_NORMAL_BIAS=Normal Bias
option.SHADOW_NORMAL_BIAS.comment=Offsets shadow samples along surface normals to reduce shadow acne (striping artifacts).

option.SHADOW_OPACITY=Shadow Opacity
option.SHADOW_OPACITY.comment=How dark shadows are. 0 = invisible, 1 = pure black shadows.

option.SHADOW_HUE=Shadow Hue
option.SHADOW_HUE.comment=Color tint angle for shadows. 0 = neutral, positive = cool/blue, negative = warm/orange.

option.SHADOW_SATURATION=Shadow Saturation
option.SHADOW_SATURATION.comment=Color saturation of shadow tint. 0 = gray shadows, higher = more vivid colored shadows.
option.BLOCKLIGHT_SHADOW_OVERRIDE=Blocklight Shadow Override
option.BLOCKLIGHT_SHADOW_OVERRIDE.comment=Lets local blocklight reduce or cancel directional sun/moon shadows around light sources.
option.LIGHTMAP_SATURATION=Lightmap Shadow Saturation
option.LIGHTMAP_SATURATION.comment=Color saturation for lightmap-based shadows (beyond shadow distance). 0 = gray, higher = more colored.

option.SKYLIGHT_DARKNESS_LEVELS=Skylight Darkness Levels
option.SKYLIGHT_DARKNESS_LEVELS.comment=Overall skylight darkening amount. At max, skylight level 1 reaches full darkening while level 15 stays unchanged.
option.SKYLIGHT_DARKNESS_Z=Skylight Darkness Curve (Z)
option.SKYLIGHT_DARKNESS_Z.comment=Controls increment progression between levels: 0.0 = x1/x1.1/x1.2..., 1.0 = x1/x2/x3...

option.DH_SHADOW_OPACITY=DH Shadow Opacity
option.DH_SHADOW_OPACITY.comment=Controls how dark shadows from the shadow map are on Distant Horizons terrain. 0.0 = no shadow darkening, 1.0 = maximum darkness.

option.DH_SATURATION=DH Color Saturation
option.DH_SATURATION.comment=Color saturation for Distant Horizons terrain. 0.0 = grayscale, 1.0 = unchanged, higher = oversaturated.

option.DH_AO_INTENSITY=DH Ambient Occlusion
option.DH_AO_INTENSITY.comment=Ambient occlusion intensity for Distant Horizons terrain. Darkens areas under trees, overhangs, etc. 0%% = off, 100%% = full.
suffix.DH_AO_INTENSITY=%%

# --- Ambient ---

screen.AMBIENT=Ambient
screen.AMBIENT.comment=Overall brightness, night darkness, cave lighting, blocklight, and skylight color tinting.

option.TERRAIN_BRIGHTNESS=Terrain Brightness
option.TERRAIN_BRIGHTNESS.comment=Overall brightness multiplier for all terrain surfaces.

option.NIGHT_DARKNESS=Night Darkness
option.NIGHT_DARKNESS.comment=Extra nighttime darkening for non-emissive, non-blocklit lighting. 0 = no extra darkening, higher = darker nights.

option.CAVE_DARKNESS=Cave Darkness
option.CAVE_DARKNESS.comment=Controls how dark the cave tint gets at the lowest skylight. Higher values deepen caves while the fade follows the cave-tint ramp.

option.BLOCKLIGHT_BRIGHTNESS=Blocklight Brightness
option.BLOCKLIGHT_BRIGHTNESS.comment=Brightness of torches, lanterns, and other block light sources.
option.BLOCKLIGHT_SKYLIGHT_REDUCTION=Blocklight Skylight Reduction
option.BLOCKLIGHT_SKYLIGHT_REDUCTION.comment=Reduces blocklight where skylight is present. Keeps blocklight stronger in caves and enclosed areas.

option.ENTITY_BRIGHTNESS_BOOST=Entity Brightness Boost
option.ENTITY_BRIGHTNESS_BOOST.comment=Blends toward flatter/brighter entity lighting. 0 = vanilla shaded, 1 = fully flat (can look very bright in sunlight).

option.AMBIENT_TINT=Ambient Tint
option.AMBIENT_TINT.comment=Shifts ambient light color. Negative = warm/orange, 0 = neutral, positive = cool/blue.

option.SKYLIGHT_COLOR_TINT=Skylight Tint Strength
option.SKYLIGHT_COLOR_TINT.comment=Overall strength of skylight color tinting on blocks (time-of-day sky + biome skyColor). Set to 0 for neutral/white skylight.

option.SKYLIGHT_TINT_SATURATION=Skylight Tint Saturation
option.SKYLIGHT_TINT_SATURATION.comment=Saturation multiplier for the sky-tinted lighting on blocks. 1 = unchanged.

option.SKYLIGHT_TINT_LIGHT_SATURATION=Bright Area Saturation
option.SKYLIGHT_TINT_LIGHT_SATURATION.comment=Extra saturation applied mainly in bright/lit areas. 0 = more neutral sunlight, 1 = full saturation.

option.SUNSET_TERRAIN_TINT=Sunset Sky Tint
option.SUNSET_TERRAIN_TINT.comment=Extra warm tint applied to terrain at sunrise and sunset. Boosts the golden-hour glow on blocks beyond the base Skylight Color Tint. 0 = no extra warmth, higher = stronger orange/gold bloom on surfaces.

# --- Emissive ---

screen.EMISSIVE=Emissive
screen.EMISSIVE.comment=Emissive block brightness and dynamic held-item light around the player.

option.EMISSIVE_MASKING=Per-Pixel Emission
option.EMISSIVE_MASKING.comment=Only the glowing parts of emissive blocks emit light. Torch flames glow but the stick does not. Lantern frames stay dark. Disable for classic full-block glow.

option.EMISSIVE_BRIGHTNESS=Emissive Brightness
option.EMISSIVE_BRIGHTNESS.comment=Brightness multiplier for emissive blocks and surfaces.
option.ENTITY_EMISSIVE_BRIGHTNESS=Entity Emission
option.ENTITY_EMISSIVE_BRIGHTNESS.comment=Visible brightness multiplier for emissive entity parts like eyes and glow layers.
option.ENTITY_EMISSIVE_BLOOM=Entity Bloom
option.ENTITY_EMISSIVE_BLOOM.comment=Bloom source strength for emissive entity parts like eyes and glow layers.

option.HANDHELD_LIGHT_ENABLED=Dynamic Handheld Light
option.HANDHELD_LIGHT_ENABLED.comment=Lights nearby terrain around the player when holding light-emitting items.

option.HANDHELD_LIGHT_STRENGTH=Handheld Light Strength
option.HANDHELD_LIGHT_STRENGTH.comment=Brightness of the handheld light contribution.

option.HANDHELD_LIGHT_RADIUS=Handheld Light Radius
option.HANDHELD_LIGHT_RADIUS.comment=Range in blocks before handheld light fades to dark.

# --- LPV (Colored Block Lighting) ---

screen.LPV=Colored Block Light (LPV)
screen.LPV.comment=Replaces vanilla warm blocklight with per-block colored lighting using 3D voxel flood-fill propagation. Torches glow warm orange, soul lanterns icy blue, glowstone golden, etc. Moderate GPU cost.

option.LPV_ENABLED=Enable LPV
option.LPV_ENABLED.comment=Turn on Light Propagation Volumes. Each light-emitting block casts its own colored light into the voxel grid around the player. Requires Iris with CUSTOM_IMAGES and COMPUTE_SHADERS support.
value.LPV_ENABLED.true=ON
value.LPV_ENABLED.false=OFF

option.LPV_VOLUME_SIZE=Volume Size
option.LPV_VOLUME_SIZE.comment=Side length of the cubic light volume in voxels. 128 = 64 block radius, 256 = 128 block radius around player.

option.LPV_STRENGTH=LPV Strength
option.LPV_STRENGTH.comment=How bright the LPV colored light appears on surfaces. Does not change how far light reaches.

option.LPV_NIGHT_STRENGTH=Night Strength
option.LPV_NIGHT_STRENGTH.comment=LPV strength multiplier at full night. 1.0 = same as day, lower = dimmer at night so torches don't overpower a dark sky. Smooth transition through dusk.

option.LPV_RADIUS=LPV Radius
option.LPV_RADIUS.comment=How far light reaches from each source. Higher = longer reach. Internally controls per-step energy conservation in the flood-fill; clamped so it cannot produce runaway amplification.

option.LPV_RENDER_DISTANCE=LPV Render Distance
option.LPV_RENDER_DISTANCE.comment=How far from the player LPV contribution is visible. Smoothly fades LPV output to zero past this distance. Does not change the underlying propagation range (use LPV Radius for that). Safe to change at runtime — no flicker.

option.LPV_FADE_OUT_DISTANCE=Fade-Out Distance
option.LPV_FADE_OUT_DISTANCE.comment=Width of the smooth fade band at the edge of render distance, in voxels (1 voxel = 1 block). Higher = softer gradient, lower = sharper cutoff.

option.LPV_VIBRANCY=LPV Vibrancy
option.LPV_VIBRANCY.comment=Saturation of LPV colored hues. 1.0 = natural, higher = more vivid/colorful, lower = closer to neutral white light.


# ============================================================================
#   2. SKY & CLOUDS
