option.FAKE_TERRAIN_START=Start Distance
option.FAKE_TERRAIN_START.comment=Distance (blocks) from the player where fake terrain begins rendering.

option.FAKE_TERRAIN_DISTANCE=Max Distance
option.FAKE_TERRAIN_DISTANCE.comment=How far the fake terrain extends from the player.

# ============================================================================
#   6. POST PROCESSING
# ============================================================================

screen.POST_PROCESSING=Post Processing
screen.POST_PROCESSING.comment=Bloom, outlines, TAA, FXAA, color correction, and color grading effects.

# --- TAA ---

screen.TAA_SETTINGS=Temporal Anti-Aliasing
screen.TAA_SETTINGS.comment=Blends frames over time for smoother volumetric clouds and reduced aliasing. Greatly improves cloud quality at no extra cost.

option.TAA_ENABLED=Enable TAA
option.TAA_ENABLED.comment=Temporal Anti-Aliasing. Blends current and previous frames together for much smoother volumetric clouds and reduced visual noise. May cause slight ghosting during fast camera movement.

option.TAA_BLEND=History Blend
option.TAA_BLEND.comment=How much of the previous frame to keep. Higher values = smoother result but more ghosting on fast movement. 0.90 is a good balance.

# --- FXAA ---

screen.FXAA_SETTINGS=FXAA Anti-Aliasing
screen.FXAA_SETTINGS.comment=Fast Approximate Anti-Aliasing. Smooths jagged block edges at distance without affecting toon outlines.

option.FXAA_ENABLED=Enable FXAA
option.FXAA_ENABLED.comment=Smooths jagged staircase edges on distant block geometry. Does not blur toon outlines (they are drawn after FXAA).

option.FXAA_QUALITY=Smoothing Quality
option.FXAA_QUALITY.comment=Sub-pixel smoothing strength. Higher = smoother edges but slightly softer image. 1.0 is a good balance.

# --- Bloom ---

screen.BLOOM=Bloom
screen.BLOOM.comment=Soft glow around bright areas and particles.

option.BLOOM_ENABLED=Enable Bloom
option.BLOOM_ENABLED.comment=Adds a soft glow effect around bright areas of the screen.

option.BLOOM_INTENSITY=Bloom Master Strength
option.BLOOM_INTENSITY.comment=Overall bloom brightness for both near and far lights.

option.BLOOM_RADIUS=Bloom Master Radius
option.BLOOM_RADIUS.comment=Overall bloom spread multiplier for both near and far lights.

option.BLOOM_CLOSE_STRENGTH=Close Strength
option.BLOOM_CLOSE_STRENGTH.comment=Bloom brightness multiplier for nearby lights.

option.BLOOM_CLOSE_RADIUS=Close Radius
option.BLOOM_CLOSE_RADIUS.comment=Bloom spread multiplier for nearby lights.

option.BLOOM_FAR_STRENGTH=Far Strength
option.BLOOM_FAR_STRENGTH.comment=Bloom brightness multiplier for distant lights.

option.BLOOM_FAR_RADIUS=Far Radius
option.BLOOM_FAR_RADIUS.comment=Bloom spread multiplier for distant lights.
option.ENTITY_BLOOM_STRENGTH=Entity Strength
option.ENTITY_BLOOM_STRENGTH.comment=Extra bloom brightness applied only to emissive entities like spider and enderman eyes.
option.ENTITY_BLOOM_RADIUS=Entity Radius
option.ENTITY_BLOOM_RADIUS.comment=Extra bloom spread applied only to emissive entities like spider and enderman eyes.

option.BLOOM_SATURATION=Bloom Saturation
option.BLOOM_SATURATION.comment=Color vividness of bloom glow. 1.0 = natural, higher = more vivid colors, 0 = grayscale bloom.

option.BLOOM_DAY_STRENGTH=Day Strength
option.BLOOM_DAY_STRENGTH.comment=Bloom intensity during daytime on the surface. Reduces bloom in bright sunlight to prevent washout. Underground areas are unaffected.

option.BLOOM_DISTANCE_COMPENSATION=Distance Boost
option.BLOOM_DISTANCE_COMPENSATION.comment=Boosts bloom on distant emissive blocks to compensate for them covering fewer pixels. 0 = off, higher = stronger boost at distance.

option.PARTICLE_BLOOM_INTENSITY=Particle Bloom
option.PARTICLE_BLOOM_INTENSITY.comment=Extra bloom intensity for particles (fire, enchant, redstone, etc.).

option.PARTICLE_BLOOM_THRESHOLD=Particle Threshold
option.PARTICLE_BLOOM_THRESHOLD.comment=Brightness threshold for particle bloom. Lower = more particles glow.

option.PARTICLE_BLOOM_WARMTH=Particle Warmth
option.PARTICLE_BLOOM_WARMTH.comment=Warm color bias for particle bloom glow.

# --- Outlines ---

screen.OUTLINES=Outlines
screen.OUTLINES.comment=Cartoon/anime-style edge outlines on geometry.

option.OUTLINES=Outline Mode
option.OUTLINES.comment=Edge outline style. Off disables outlines. Standard draws clean edges. Dungeons style adds thicker, stylized edges.

value.OUTLINES.0=Off
value.OUTLINES.1=Standard
value.OUTLINES.2=Dungeons Style

option.OUTLINE_BRIGHTNESS=Outline Brightness
option.OUTLINE_BRIGHTNESS.comment=Brightness of the outlines. Negative = darker outlines (black lines), positive = brighter outlines (white lines).
option.OUTLINE_SATURATION=Outline Saturation
option.OUTLINE_SATURATION.comment=How vivid the outline color is. 1 = current scene color, higher = more saturated outlines, 0 = grayscale.

option.OUTLINE_PIXEL_SIZE=Outline Thickness
option.OUTLINE_PIXEL_SIZE.comment=Thickness of outlines in pixels. Higher = thicker, more visible lines.

# --- Color Correction ---

screen.COLOR_CORRECTION=Color Correction
screen.COLOR_CORRECTION.comment=Sharpening, saturation, contrast, and brightness adjustments.

option.POST_SHARPEN=Enable Sharpening
option.POST_SHARPEN.comment=Applies a sharpening filter to the final image. Adds edge definition.

option.POST_SHARPEN_STRENGTH=Sharpen Strength
option.POST_SHARPEN_STRENGTH.comment=How aggressively edges are sharpened. Higher = more noticeable but may add artifacts.

option.POST_SATURATION=Saturation
option.POST_SATURATION.comment=Color saturation of the final image. 1 = unchanged, lower = washed out, higher = more vivid.

option.POST_CONTRAST=Contrast
option.POST_CONTRAST.comment=Contrast of the final image. 1 = unchanged, lower = flatter, higher = punchier darks and lights.

option.POST_BRIGHTNESS=Brightness
option.POST_BRIGHTNESS.comment=Brightness offset applied to the final image. 0 = unchanged.

# --- Color Grading ---

screen.COLOR_GRADING=Color Grading
screen.COLOR_GRADING.comment=Professional color grading tools: style presets, temperature, split toning, lift/gamma/gain, and creative effects.

option.COLOR_GRADING_ENABLED=Enable Color Grading
option.COLOR_GRADING_ENABLED.comment=Master toggle for all color grading effects below.

screen.CG_STYLE_PRESETS=Style Presets
