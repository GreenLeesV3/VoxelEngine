option.CG_VIBRANCE=Vibrance
option.CG_VIBRANCE.comment=Intelligent saturation that boosts less-saturated colors more than already-vivid ones. Negative = desaturate.

screen.CG_EFFECTS=Effects
screen.CG_EFFECTS.comment=Posterization, texture palette, vignette, and film grain.

