value.CG_STYLE_PRESET.3=Cyberpunk
value.CG_STYLE_PRESET.4=Horror
value.CG_STYLE_PRESET.5=Fantasy
value.CG_STYLE_PRESET.6=Nordic
value.CG_STYLE_PRESET.7=Tropical
value.CG_STYLE_PRESET.8=Noir

option.CG_STYLE_INTENSITY=Preset Intensity
option.CG_STYLE_INTENSITY.comment=Blends between no preset (0) and full preset effect (1). Use to subtly mix in a preset look.

screen.CG_TEMPERATURE_TINT=Temperature & Tint
screen.CG_TEMPERATURE_TINT.comment=White balance adjustment. Temperature shifts warm/cool, tint shifts green/magenta.

option.CG_TEMPERATURE=Temperature
option.CG_TEMPERATURE.comment=Color temperature shift. Negative = cool/blue, positive = warm/orange.

option.CG_TINT=Tint
option.CG_TINT.comment=Color tint shift. Negative = green, positive = magenta.

