screen.CG_LIFT=Lift (Shadows)
screen.CG_LIFT.comment=Per-channel shadow color adjustment. Values below 1 darken, above 1 brighten shadow tones.

option.CG_LIFT_R=Red
option.CG_LIFT_G=Green
option.CG_LIFT_B=Blue

screen.CG_GAMMA=Gamma (Midtones)
screen.CG_GAMMA.comment=Per-channel midtone color adjustment. Values below 1 brighten, above 1 darken midtones.

option.CG_GAMMA_R=Red
option.CG_GAMMA_G=Green
option.CG_GAMMA_B=Blue

screen.CG_GAIN=Gain (Highlights)
