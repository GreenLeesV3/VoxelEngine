option.END_VORTEX_ENABLED=Enable Void Vortex
option.END_VORTEX_ENABLED.comment=Warps the sky below the island like gravitational lensing ? stars and nebula get stretched and pulled inward toward a central point.

option.END_VORTEX_INTENSITY=Intensity
option.END_VORTEX_INTENSITY.comment=Brightness of the vortex light streaks. Higher = more visible.

option.END_VORTEX_SPEED=Rotation Speed
option.END_VORTEX_SPEED.comment=How fast the spiral rotates.

option.END_VORTEX_ARMS=Spiral Arms
option.END_VORTEX_ARMS.comment=Number of spiral arms. More arms = denser pattern.

option.END_VORTEX_TIGHTNESS=Spiral Tightness
option.END_VORTEX_TIGHTNESS.comment=How tightly the light spirals inward. Higher = more coiled.

option.END_VORTEX_CORE_SIZE=Core Glow Size
option.END_VORTEX_CORE_SIZE.comment=Size of the subtle glow at the very center of the vortex.

option.END_VORTEX_R2=Glow Red
option.END_VORTEX_G2=Glow Green
option.END_VORTEX_B2=Glow Blue

# --- End Rings ---

screen.END_RINGS_SETTINGS=Planetary Rings
screen.END_RINGS_SETTINGS.comment=Saturn-like rings centered on the End island. Fixed in world space with proper perspective.

screen.END_RINGS_COLOR=Ring Color
screen.END_RINGS_COLOR.comment=Base color for the planetary rings.

option.END_RINGS_ENABLED=Enable Planetary Rings
option.END_RINGS_ENABLED.comment=Adds glowing planetary rings around the End center island, like Saturn's rings. Fixed in world space at (0, 64, 0).

option.END_RINGS_COUNT=Number of Rings
option.END_RINGS_COUNT.comment=How many ring bands to render. Each band is at a different distance and tilt.

option.END_RINGS_BRIGHTNESS=Brightness
option.END_RINGS_BRIGHTNESS.comment=Overall brightness of the rings.

option.END_RINGS_SPEED=Precession Speed
option.END_RINGS_SPEED.comment=How fast the ring tilts rotate (precession). Set to 0 for static rings.

option.END_RINGS_INNER=Inner Radius
option.END_RINGS_INNER.comment=Distance (in blocks) from the island center to the inner edge of the first ring.

option.END_RINGS_WIDTH=Band Width
option.END_RINGS_WIDTH.comment=Width of each ring band in blocks. The total ring system extends from Inner Radius to Inner Radius + Width + (Count x 30).

option.END_RINGS_DEPTH=Ring Thickness
option.END_RINGS_DEPTH.comment=Vertical thickness of the ring slab in blocks. Gives the ring 3D depth ? thicker rings glow brighter at glancing angles.

option.END_RINGS_R=Ring Red
option.END_RINGS_G=Ring Green
option.END_RINGS_B=Ring Blue

# --- End Void Clouds ---

screen.END_VOID_CLOUDS_SETTINGS=Void Clouds
screen.END_VOID_CLOUDS_SETTINGS.comment=Volumetric swirling clouds that wrap around the End island, creating a cosmic storm tunnel effect.

screen.END_VOID_CLOUD_COLOR1=Cloud Color 1
screen.END_VOID_CLOUD_COLOR1.comment=Primary cloud color (default: deep purple).

screen.END_VOID_CLOUD_COLOR2=Cloud Color 2
screen.END_VOID_CLOUD_COLOR2.comment=Secondary cloud color for variation (default: dark indigo).

option.END_VOID_CLOUDS_ENABLED=Enable Void Clouds
option.END_VOID_CLOUDS_ENABLED.comment=Volumetric-style swirling clouds that create a dramatic tunnel wrapping around the End island. Uses raymarching for convincing depth and thickness.

option.END_VOID_CLOUD_INTENSITY=Cloud Brightness
option.END_VOID_CLOUD_INTENSITY.comment=Overall brightness of the void clouds.

option.END_VOID_CLOUD_STEPS=Quality (Steps)
option.END_VOID_CLOUD_STEPS.comment=Raymarch steps for cloud rendering. Higher = better quality but more expensive. 8 = fast, 16 = balanced, 32 = high quality.

option.END_VOID_CLOUD_COVERAGE=Cloud Coverage
option.END_VOID_CLOUD_COVERAGE.comment=How much of the sky is filled with clouds. Lower = more clouds, higher = more gaps and open sky.

option.END_VOID_CLOUD_DENSITY=Cloud Thickness
option.END_VOID_CLOUD_DENSITY.comment=Optical density of the clouds. Higher = more opaque and solid-looking.

option.END_VOID_CLOUD_SCALE=Cloud Scale
option.END_VOID_CLOUD_SCALE.comment=Size of the cloud formations. Lower = bigger sweeping formations, higher = smaller more detailed.

option.END_VOID_CLOUD_SPEED=Drift Speed
option.END_VOID_CLOUD_SPEED.comment=How fast the clouds drift through space. 0 = frozen.

option.END_VOID_CLOUD_SWIRL=Swirl Tightness
option.END_VOID_CLOUD_SWIRL.comment=How tightly the clouds spiral. 0 = no swirl (straight clouds), 10 = tight vortex. Creates the tunnel/storm effect.

option.END_VOID_CLOUD_SWIRL_SPEED=Swirl Rotation
option.END_VOID_CLOUD_SWIRL_SPEED.comment=How fast the spiral pattern rotates.

option.END_VOID_CLOUD_CLEARING=Island Clearing
option.END_VOID_CLOUD_CLEARING.comment=Width of the clear zone around the horizon where the island sits. Higher = wider opening in the clouds.

option.END_VOID_CLOUD_EDGE_GLOW=Edge Glow
option.END_VOID_CLOUD_EDGE_GLOW.comment=Brightness boost at cloud edges, creating a silver-lining or internal-glow effect.

option.END_VOID_CLOUD_R1=Color 1 Red
option.END_VOID_CLOUD_G1=Color 1 Green
option.END_VOID_CLOUD_B1=Color 1 Blue

option.END_VOID_CLOUD_R2=Color 2 Red
option.END_VOID_CLOUD_G2=Color 2 Green
option.END_VOID_CLOUD_B2=Color 2 Blue

# --- End Ender Particles ---

screen.END_ENDER_PARTICLES_SETTINGS=Ender Particles
screen.END_ENDER_PARTICLES_SETTINGS.comment=Floating glowing motes drifting in the air around the player in the End dimension.

option.END_ENDER_PARTICLES_ENABLED=Enable Ender Particles
option.END_ENDER_PARTICLES_ENABLED.comment=Floating glowing motes drifting in the air around the player. Purple, magenta, and cyan particles that add atmosphere to the End.

option.END_ENDER_PARTICLE_DENSITY=Particle Density
option.END_ENDER_PARTICLE_DENSITY.comment=How many particles appear. Higher = more particles in the air.

option.END_ENDER_PARTICLE_BRIGHTNESS=Brightness
option.END_ENDER_PARTICLE_BRIGHTNESS.comment=How bright the floating particles glow.

option.END_ENDER_PARTICLE_SIZE=Particle Size
option.END_ENDER_PARTICLE_SIZE.comment=Size of each individual particle mote.

option.END_ENDER_PARTICLE_SPACING=Spacing
option.END_ENDER_PARTICLE_SPACING.comment=Distance between particle grid cells. Smaller = denser field, larger = more spread out.

option.END_ENDER_PARTICLE_RANGE=View Range
option.END_ENDER_PARTICLE_RANGE.comment=How far away particles are visible. Higher = particles visible at greater distance.

# --- End Void Particles ---

screen.END_VOID_PARTICLES_SETTINGS=End Void Particles
screen.END_VOID_PARTICLES_SETTINGS.comment=Small pulsing specks drifting through the End void.

option.END_VOID_PARTICLES_ENABLED=Enable Void Particles
option.END_VOID_PARTICLES_ENABLED.comment=Small glowing specks that pulse and drift through the End void.

option.END_VOID_PARTICLE_DENSITY=Particle Density
option.END_VOID_PARTICLE_DENSITY.comment=How many void particles appear in the sky.

option.END_VOID_PARTICLE_BRIGHTNESS=Particle Brightness
option.END_VOID_PARTICLE_BRIGHTNESS.comment=Brightness of individual void particles.

# --- End Warp Streaks ---

screen.END_ASTEROIDS_SETTINGS=Warp Streaks
screen.END_ASTEROIDS_SETTINGS.comment=Rare, fast-flying streaks that zip across the End sky ? like asteroids or debris flashing past at high speed.

option.END_ASTEROIDS_ENABLED=Enable Warp Streaks
option.END_ASTEROIDS_ENABLED.comment=Rare, fast streaks that flash across the End sky like debris flying past at high speed.

option.END_ASTEROID_DENSITY=Frequency
option.END_ASTEROID_DENSITY.comment=How often warp streaks appear. Lower = rarer and more dramatic.

option.END_ASTEROID_SPEED=Speed
option.END_ASTEROID_SPEED.comment=How fast the streaks zip across the sky.

option.END_ASTEROID_BRIGHTNESS=Brightness
option.END_ASTEROID_BRIGHTNESS.comment=Brightness of the warp streaks.

option.END_ASTEROID_LENGTH=Streak Length
option.END_ASTEROID_LENGTH.comment=How long each streak trail is.

option.END_ASTEROID_THICKNESS=Streak Thickness
option.END_ASTEROID_THICKNESS.comment=How thick each streak is.

# --- End Lighting ---

screen.END_LIGHTING_SETTINGS=End Lighting
screen.END_LIGHTING_SETTINGS.comment=Blocklight, emissive brightness, and bloom settings for the End dimension. Makes lit areas and glowing blocks stand out.

option.END_BLOCKLIGHT_BRIGHTNESS=Blocklight Brightness
option.END_BLOCKLIGHT_BRIGHTNESS.comment=How bright block light sources appear in the End. Higher values make lit areas stand out more from the dark ambient.

option.END_EMISSIVE_BOOST=Emissive Boost
option.END_EMISSIVE_BOOST.comment=Brightness multiplier for glowing blocks (end rods, glowstone, etc.) in the End. Makes emissive blocks pop against dark terrain.

option.END_BLOOM_BOOST=Bloom Boost
option.END_BLOOM_BOOST.comment=Bloom intensity multiplier for the End dimension. Higher values create stronger glow halos around emissive blocks.

option.END_BLOCKLIGHT_R=Light Tint Red
option.END_BLOCKLIGHT_G=Light Tint Green
option.END_BLOCKLIGHT_B=Light Tint Blue

# --- End Terrain Patches ---

screen.END_TERRAIN_PATCHES_SETTINGS=Terrain Patches
screen.END_TERRAIN_PATCHES_SETTINGS.comment=Adds patches of slight darkness to End ground for visual variety on flat end stone.

option.END_TERRAIN_PATCHES_ENABLED=Enable Terrain Patches
option.END_TERRAIN_PATCHES_ENABLED.comment=Adds random patches of slight darkness to End ground surfaces, giving the flat yellow end stone more visual variety and texture.

option.END_TERRAIN_PATCH_STRENGTH=Patch Darkness
option.END_TERRAIN_PATCH_STRENGTH.comment=How much darker the patches are. 0.25 = subtle shading, 0.50 = very noticeable.

option.END_TERRAIN_PATCH_SCALE=Patch Scale
option.END_TERRAIN_PATCH_SCALE.comment=Controls the size of the patches. Lower = larger patches (up to ~10 blocks), higher = smaller more detailed patches.

# --- End Fog ---

screen.END_FOG_SETTINGS=End Fog
screen.END_FOG_SETTINGS.comment=Dark depth fog that fades distant blocks into the void.

option.END_FOG_ENABLED=Enable End Fog
option.END_FOG_ENABLED.comment=Dark depth fog that fades distant blocks into the void. Works with both volumetric and distance fog modes.

option.END_FOG_DISTANCE=Fog Distance
option.END_FOG_DISTANCE.comment=Distance where End fog reaches full thickness. Shorter = denser void.

option.END_FOG_START=Fog Start
option.END_FOG_START.comment=Distance from camera where End fog begins. No fog closer than this.

option.END_FOG_DENSITY=Fog Density
option.END_FOG_DENSITY.comment=How thick the End fog is. Higher = denser, more opaque void mist.

option.END_FOG_R=Fog Red
option.END_FOG_G=Fog Green
option.END_FOG_B=Fog Blue

