# --- Clouds ---

screen.CLOUDS=Clouds
screen.CLOUDS.comment=Cloud settings. Choose between 3D volumetric or 2D flat clouds.

screen.CLOUDS_3D_SETTINGS=3D Volumetric Clouds
screen.CLOUDS_3D_SETTINGS.comment=Raymarched 3D clouds with depth, lighting, and multiple height layers. Stylized cartoonish look.

screen.CLOUDS_2D_SETTINGS=2D Flat Clouds
screen.CLOUDS_2D_SETTINGS.comment=Simple flat 2D clouds. Lightweight alternative to 3D clouds.

screen.CLOUD_3D_COLOR=Cloud Color
screen.CLOUD_3D_COLOR.comment=Customize the base color of 3D clouds.

option.CLOUDS_3D_ENABLED=Enable 3D Clouds
option.CLOUDS_3D_ENABLED.comment=Raymarched volumetric 3D clouds with depth and lighting. Stylized, cartoonish, white puffy clouds at varying heights.

option.CLOUDS_2D_ENABLED=Enable 2D Clouds
option.CLOUDS_2D_ENABLED.comment=Simple flat 2D clouds rendered on a plane. Lightweight alternative.

option.CLOUD_SHADOWS_ENABLED=Cloud Shadows
option.CLOUD_SHADOWS_ENABLED.comment=Toggle terrain cloud shadows.

option.CLOUD_3D_STEPS=Quality (Steps)
option.CLOUD_3D_STEPS.comment=Raymarch steps for 3D cloud rendering. Higher = better quality but slower. 16 = fast, 24 = balanced, 48 = high quality.

option.CLOUD_3D_COVERAGE=Coverage
option.CLOUD_3D_COVERAGE.comment=How much of the sky is filled with clouds. Lower = more open sky, higher = overcast.

option.CLOUD_3D_DENSITY=Density
option.CLOUD_3D_DENSITY.comment=Optical density of the clouds. Higher = more opaque and solid-looking.

option.CLOUD_3D_HEIGHT=Height
option.CLOUD_3D_HEIGHT.comment=Height of the main cloud layer in blocks above sea level.

option.CLOUD_3D_THICKNESS=Thickness
option.CLOUD_3D_THICKNESS.comment=Vertical thickness of the cloud layer in blocks.

option.CLOUD_3D_SCALE=Scale
option.CLOUD_3D_SCALE.comment=Size of cloud formations. Lower = bigger sweeping clouds, higher = smaller more detailed.

option.CLOUD_3D_CELL_SIZE=Cell Size
option.CLOUD_3D_CELL_SIZE.comment=Size of each cloud grid cell in blocks. Controls how large each rectangular cloud "pixel" is. Smaller = more detailed blocky pattern, larger = bigger blocky chunks.

option.CLOUD_3D_DETAIL=Detail
option.CLOUD_3D_DETAIL.comment=Erosion detail strength. Adds puffy cauliflower bumps to cloud edges. 0 = smooth blobs, higher = more textured.

option.CLOUD_3D_SPEED=Speed
option.CLOUD_3D_SPEED.comment=How fast the clouds drift across the sky. 0 = frozen.

option.CLOUD_3D_DISTANCE=Render Distance
option.CLOUD_3D_DISTANCE.comment=How far 3D clouds render from the player (in blocks). Clouds fade out smoothly near the edge. Lower = better performance.

option.CLOUD_3D_BRIGHTNESS=Brightness
option.CLOUD_3D_BRIGHTNESS.comment=Overall brightness of the 3D clouds.

option.CLOUD_3D_EDGE_GLOW=Edge Glow
option.CLOUD_3D_EDGE_GLOW.comment=Brightness boost at thin cloud edges, creating a silver-lining effect.

option.CLOUD_3D_R=Red
option.CLOUD_3D_G=Green
option.CLOUD_3D_B=Blue

