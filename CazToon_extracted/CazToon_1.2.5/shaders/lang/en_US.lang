screen.SKY_AND_CLOUDS=Sky & Clouds
screen.SKY_AND_CLOUDS.comment=Sky gradient, sun/moon, stars, planets, clouds, and time-of-day sky colors.

# --- Sky General ---

screen.SKY_GENERAL=Sky General
screen.SKY_GENERAL.comment=Base sky gradient shape, saturation, and biome color blending.

option.SKY_GRADIENT_CURVE=Gradient Curve
option.SKY_GRADIENT_CURVE.comment=Controls how quickly the sky transitions from horizon to zenith color. Higher = faster transition, more concentrated horizon band.

option.SKY_SATURATION=Sky Saturation
option.SKY_SATURATION.comment=Color saturation of the sky. 1 = normal, higher = more vivid sky colors.

option.SKY_BIOME_BLEND=Biome Blend
option.SKY_BIOME_BLEND.comment=How much biome sky color influences the overall sky. 0 = ignore biomes, 1 = full biome color.
option.SKY_RAIN_DARKNESS=Rain Sky Darkness
option.SKY_RAIN_DARKNESS.comment=How much the sky darkens during rain. Only affects the sky gradient, not terrain or LODs.

option.OVERWORLD_BIOME_SKY_ENABLED=Hard-Coded Biome Skies
option.OVERWORLD_BIOME_SKY_ENABLED.comment=Master switch for the custom overworld biome sky colors (snowy/swamp/jungle/savanna/desert/pale garden). Disable to keep the default blue sky everywhere in the overworld; also clears biome tint from the water sky reflection. Nether and End skies are unaffected.
suffix.SKY_RAIN_DARKNESS=%

# --- Sun & Moon ---

screen.SUN_MOON=Sun & Moon
screen.SUN_MOON.comment=Sun path angle, sun/moon size, and glow bloom settings.

option.sunPathRotation=Sun Path Rotation
option.sunPathRotation.comment=Rotates the sun/moon arc across the sky (in degrees). Changes shadow angles and lighting direction.

option.SUN_MOON_SIZE_ENABLED=Custom Sun/Moon Size
option.SUN_MOON_SIZE_ENABLED.comment=Enable custom sun and moon sizing. Disable for vanilla size.

option.SUN_MOON_SCALE=Sun/Moon Scale
option.SUN_MOON_SCALE.comment=Size multiplier for the sun and moon disc. Smaller values = smaller sun/moon.

option.SUN_MOON_BLOOM=Sun/Moon Bloom
option.SUN_MOON_BLOOM.comment=Glow intensity around the sun and moon. 0 = no glow, higher = brighter halo.

option.SUN_GLOW_RADIUS=Sun Glow Radius
option.SUN_GLOW_RADIUS.comment=Size of the soft radial halo around the sun. Independent of the bloom blur radius.

option.SUN_GLOW_INTENSITY=Sun Glow Strength
option.SUN_GLOW_INTENSITY.comment=Brightness of the sun's radial halo. 0 = off, higher = brighter glow.

option.SUN_BRIGHTNESS_BOOST=Sun Look Brightness
option.SUN_BRIGHTNESS_BOOST.comment=Subtly brightens the screen when looking toward the sun. Strongest when the sun is at the center of your view.

